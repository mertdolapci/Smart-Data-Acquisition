#include "svc_monitoring.h"

#include "FreeRTOS.h"
#include "task.h"

uint32_t SvcMonitoring_GetFreeHeapBytes(void)
{
    return (uint32_t)xPortGetFreeHeapSize();
}

uint32_t SvcMonitoring_GetMinEverFreeHeapBytes(void)
{
    return (uint32_t)xPortGetMinimumEverFreeHeapSize();
}

uint32_t SvcMonitoring_GetTaskStackWatermarkWords(osThreadId_t thread)
{
    if (thread == NULL)
    {
        return (uint32_t)uxTaskGetStackHighWaterMark(NULL);
    }

    return (uint32_t)uxTaskGetStackHighWaterMark((TaskHandle_t)thread);
}

uint32_t SvcMonitoring_GetTaskStackWatermarkBytes(osThreadId_t thread)
{
    return SvcMonitoring_GetTaskStackWatermarkWords(thread) * sizeof(StackType_t);
}
