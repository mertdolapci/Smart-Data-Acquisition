#include "task_monitoring.h"
#include "svc_log.h"
#include "cmsis_os2.h"
#include "FreeRTOS.h"
#include "task.h"


extern TaskHandle_t g_appControlTaskHandle;


void MonitorTask(void *argument)
{
    (void)argument;

    LOGI("MonitorTask started");

    for (;;)
    {
    	size_t FreeHeapSize = xPortGetFreeHeapSize();
    	size_t MinHeapSize xPortGetMinimumEverFreeHeapSize();

    	UBaseType_t monitor_wm = uxTaskGetStackHighWaterMark(NULL);
    	UBaseType_t app_wm = uxTaskGetStackHighWaterMark((TaskHandle_t)g_appControlTaskHandle);

    	LOGI("Monitor Stack WM : %lu words", (uint32_t)monitor_wm);

    	LOGI("AppCtrl Stack WM : %lu words", (uint32_t)app_wm);

        osDelay(5000);
        LOGI("Monitor tick");
    }
}
